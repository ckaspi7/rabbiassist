    {
      "parameters": {
        "jsCode": "// Group trip items by trip_id and analyze what's missing or not booked\nconst tripItems = $input.all();\nconst trips = $('Get Future Trips').all();\nconst requiredTypes = $('Set Workflow Variables').first().json.required_trip_types;\n\nconst results = [];\n\n// Create a map of trips for easy lookup - use Map for better type safety\nconst tripMap = new Map();\ntrips.forEach(trip => {\n  tripMap.set(String(trip.json.id), trip.json);\n});\n\n// Group items by trip_id - use Map for better type safety\nconst itemsByTrip = new Map();\ntripItems.forEach(item => {\n  const tripId = String(item.json.trip_id);\n  if (!itemsByTrip.has(tripId)) {\n    itemsByTrip.set(tripId, []);\n  }\n  itemsByTrip.get(tripId).push(item.json);\n});\n\n// Debug: Log what we have\nconsole.log('Trip Map keys:', Array.from(tripMap.keys()));\nconsole.log('Items by trip keys:', Array.from(itemsByTrip.keys()));\n\n// Check each trip for missing or unbooked items\nfor (const [tripId, trip] of tripMap) {\n  const items = itemsByTrip.get(tripId) || [];\n  \n  // Check if trip needs reminders (30 days or 15 days before)\n  const startDate = new Date(trip.start_date);\n  const now = new Date();\n  const daysUntilTrip = Math.ceil((startDate - now) / (1000 * 60 * 60 * 24));\n\n  console.log(`Trip ${tripId}: ${daysUntilTrip} days until trip`);\n\n  const needs30DayReminder = daysUntilTrip <= 30 && daysUntilTrip > 15;\n  const needs15DayReminder = daysUntilTrip <= 15 && daysUntilTrip > 0;\n  \n  if (needs30DayReminder || needs15DayReminder) {\n    const existingTypes = items.map(item => item.type).filter(type => type);\n    const bookedTypes = items.filter(item => item.status === 'booked').map(item => item.type);\n    \n    const issues = [];\n    \n    // Check for missing types\n    requiredTypes.forEach(type => {\n      if (!existingTypes.includes(type)) {\n        issues.push({\n          type: 'missing',\n          category: type,\n          message: `${type.replace('_', ' ')} not planned`\n        });\n      } else if (!bookedTypes.includes(type)) {\n        issues.push({\n          type: 'not_booked',\n          category: type,\n          message: `${type.replace('_', ' ')} not booked`\n        });\n      }\n    });\n    \n    if (issues.length > 0) {\n      results.push({\n        user_id: trip.user_id,\n        trip_id: tripId,\n        trip_name: `Trip to ${trip.destination}`,\n        start_date: trip.start_date,\n        days_until_trip: daysUntilTrip,\n        reminder_type: needs15DayReminder ? '15_day' : '30_day',\n        issues: issues\n      });\n    }\n  }\n}\n\nreturn results;"
      },
