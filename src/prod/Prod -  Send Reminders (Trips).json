    {
      "parameters": {
        "jsCode": "// Filter out trips that already have reminders sent\nconst tripsNeedingReminders = $('Analyze Trip Requirements').all();\nconst existingReminders = $input.all();\n\nconst results = [];\n\ntripsNeedingReminders.forEach(trip => {\n  const tripData = trip.json;\n  \n  // Check if this trip already has this reminder type sent\n  const reminderExists = existingReminders.some(reminder => \n    reminder.json.trip_id === tripData.trip_id && \n    reminder.json.reminder_type === tripData.reminder_type &&\n    reminder.json.reminder_sent === true\n  );\n  \n  if (!reminderExists) {\n    results.push(tripData);\n  }\n});\n\nreturn results;"
      },
