                  {
                      "parameters":  {
                                         "jsCode":  "const output = [];\nfor (const item of $(\u0027When Executed by Another Workflow\u0027).all()) {\n  for (const [key, value] of Object.entries(item.binary || {})) {\n    // Get original extension if available, fallback to mime type-derived\n    const originalName = value.fileName || \u0027unknown\u0027;\n    const extension = originalName.includes(\u0027.\u0027)\n      ? originalName.split(\u0027.\u0027).pop()\n      : (value.mimeType?.split(\u0027/\u0027)[1] || \u0027bin\u0027);\n    const fileName = originalName.includes(\u0027.\u0027)\n      ? originalName\n      : `unknown.${extension}`;\n\n    output.push({\n      binary: {\n        data: value\n      },\n      json: {\n        originalKey: key,\n        fileName: fileName,\n        mimeType: value.mimeType || \u0027unknown\u0027\n      }\n    });\n  }\n}\nreturn output;"
                                     },
