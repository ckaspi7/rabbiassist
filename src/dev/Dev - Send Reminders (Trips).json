                  {
                      "parameters":  {
                                         "jsCode":  "// Filter out trips that already have reminders sent\nconst tripsNeedingReminders = $(\u0027Analyze Trip Requirements\u0027).all();\nconst existingReminders = $input.all();\n\nconst results = [];\n\ntripsNeedingReminders.forEach(trip =\u003e {\n  const tripData = trip.json;\n  \n  // Check if this trip already has this reminder type sent\n  const reminderExists = existingReminders.some(reminder =\u003e \n    reminder.json.trip_id === tripData.trip_id \u0026\u0026 \n    reminder.json.reminder_type === tripData.reminder_type \u0026\u0026\n    reminder.json.reminder_sent === true\n  );\n  \n  if (!reminderExists) {\n    results.push(tripData);\n  }\n});\n\nreturn results;"
                                     },
