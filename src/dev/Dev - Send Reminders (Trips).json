                      "id":  "21943aa2-1c58-4443-8205-aecbfc2af857",
                      "name":  "Remove Duplicates"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "// Group trip items by trip_id and analyze what\u0027s missing or not booked\nconst tripItems = $input.all();\nconst trips = $(\u0027Get Future Trips\u0027).all();\nconst requiredTypes = $(\u0027Set Workflow Variables\u0027).first().json.required_trip_types;\n\nconst results = [];\n\n// Create a map of trips for easy lookup - use Map for better type safety\nconst tripMap = new Map();\ntrips.forEach(trip =\u003e {\n  tripMap.set(String(trip.json.id), trip.json);\n});\n\n// Group items by trip_id - use Map for better type safety\nconst itemsByTrip = new Map();\ntripItems.forEach(item =\u003e {\n  const tripId = String(item.json.trip_id);\n  if (!itemsByTrip.has(tripId)) {\n    itemsByTrip.set(tripId, []);\n  }\n  itemsByTrip.get(tripId).push(item.json);\n});\n\n// Debug: Log what we have\nconsole.log(\u0027Trip Map keys:\u0027, Array.from(tripMap.keys()));\nconsole.log(\u0027Items by trip keys:\u0027, Array.from(itemsByTrip.keys()));\n\n// Check each trip for missing or unbooked items\nfor (const [tripId, trip] of tripMap) {\n  const items = itemsByTrip.get(tripId) || [];\n  \n  // Check if trip needs reminders (30 days or 15 days before)\n  const startDate = new Date(trip.start_date);\n  const now = new Date();\n  const daysUntilTrip = Math.ceil((startDate - now) / (1000 * 60 * 60 * 24));\n\n  console.log(`Trip ${tripId}: ${daysUntilTrip} days until trip`);\n\n  const needs30DayReminder = daysUntilTrip \u003c= 30 \u0026\u0026 daysUntilTrip \u003e 15;\n  const needs15DayReminder = daysUntilTrip \u003c= 15 \u0026\u0026 daysUntilTrip \u003e 0;\n  \n  if (needs30DayReminder || needs15DayReminder) {\n    const existingTypes = items.map(item =\u003e item.type).filter(type =\u003e type);\n    const bookedTypes = items.filter(item =\u003e item.status === \u0027booked\u0027).map(item =\u003e item.type);\n    \n    const issues = [];\n    \n    // Check for missing types\n    requiredTypes.forEach(type =\u003e {\n      if (!existingTypes.includes(type)) {\n        issues.push({\n          type: \u0027missing\u0027,\n          category: type,\n          message: `${type.replace(\u0027_\u0027, \u0027 \u0027)} not planned`\n        });\n      } else if (!bookedTypes.includes(type)) {\n        issues.push({\n          type: \u0027not_booked\u0027,\n          category: type,\n          message: `${type.replace(\u0027_\u0027, \u0027 \u0027)} not booked`\n        });\n      }\n    });\n    \n    if (issues.length \u003e 0) {\n      results.push({\n        user_id: trip.user_id,\n        trip_id: tripId,\n        trip_name: `Trip to ${trip.destination}`,\n        start_date: trip.start_date,\n        days_until_trip: daysUntilTrip,\n        reminder_type: needs15DayReminder ? \u002715_day\u0027 : \u002730_day\u0027,\n        issues: issues\n      });\n    }\n  }\n}\n\nreturn results;"
                                     },
